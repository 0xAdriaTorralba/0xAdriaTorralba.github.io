<div class="col mb-4">
  <div class="card h-100 hoverable">
    <div class="row no-gutters">
      {% if talk.img %}
        <div class="col-md-4 p-0" style="position: relative; overflow: hidden; min-height: 200px;">
          <img src="{{ talk.img | relative_url }}" alt="talk thumbnail" loading="eager" style="object-fit: cover; width: 100%; height: 100%; position: absolute; top: 0; left: 0;">
        </div>
      {% endif %}
      <div class="{% if talk.img %}col-md-8{% else %}col-md-12{% endif %}">
        <div class="card-body">
          <a href="{{ talk.url | relative_url }}">
            <h3 class="card-title">{{ talk.title }}</h3>
          </a>
          {% if talk.talk_date %}<p class="card-text text-muted" style="font-size: 0.85rem; margin-bottom: 0.4rem;">{{ talk.talk_date }}</p>{% endif %}
          <p class="card-text">{{ talk.description }}</p>
          <div class="row ml-1 mr-1 p-0">
            {% if talk.youtube_url %}
              <div class="icon" data-toggle="tooltip" title="Watch Recording">
                <a href="{{ talk.youtube_url }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-youtube"></i></a>
              </div>
            {% endif %}
            {% if talk.slides_url %}
              <div class="icon" data-toggle="tooltip" title="View Slides" style="margin-left: 0.5rem;">
                <a href="{{ talk.slides_url }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-file-powerpoint"></i></a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
