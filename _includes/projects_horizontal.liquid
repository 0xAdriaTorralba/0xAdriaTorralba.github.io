<div class="col mb-4">
  <div class="card h-100 hoverable">
    <div class="row no-gutters">
      {% if project.img %}
        <div class="col-md-6">
          {% include figure.liquid loading="eager" path=project.img sizes="(min-width: 768px) 156px, 50vw" alt="project thumbnail" class="card-img" %}
        </div>
      {% endif %}
      <div class="{% if project.img %}col-md-6{% else %}col-md-12{% endif %}">
        <div class="card-body">
          <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">
            <h3 class="card-title">{{ project.title }}</h3>
          </a>
          {% if project.project_date %}
            <p class="card-text text-muted" style="font-size: 0.85rem; margin-bottom: 0.4rem;">{{ project.project_date }}</p>
          {% endif %}
          <p class="card-text">{{ project.description }}</p>
          <div class="row ml-1 mr-1 p-0">
            {% if project.github %}
              <div class="github-icon">
                <div class="icon" data-toggle="tooltip" title="Code Repository">
                  <a href="{{ project.github }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-github gh-icon"></i></a>
                </div>
                {% if project.github_stars %}
                  <span class="stars" data-toggle="tooltip" title="GitHub Stars">
                    <i class="fa-solid fa-star"></i>
                    <span id="{{ project.github_stars }}-stars"></span>
                  </span>
                {% endif %}
              </div>
            {% endif %}
            {% if project.twitter_url %}
              <div class="icon" data-toggle="tooltip" title="Twitter Post" style="margin-left: 0.5rem;">
                <a href="{{ project.twitter_url }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-x-twitter"></i></a>
              </div>
            {% endif %}
            {% if project.linkedin_url %}
              <div class="icon" data-toggle="tooltip" title="LinkedIn Post" style="margin-left: 0.5rem;">
                <a href="{{ project.linkedin_url }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-linkedin"></i></a>
              </div>
            {% endif %}
            {% if project.demo_url %}
              <div class="icon" data-toggle="tooltip" title="Live Demo" style="margin-left: 0.5rem;">
                <a href="{{ project.demo_url }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-play"></i></a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
