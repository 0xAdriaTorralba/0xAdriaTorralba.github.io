{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/contributions.json",
  "title": "Auto-generated open-source PR list",
  "description": "Schema for _data/contributions.yml. Auto-refreshed daily by scripts/refresh_contributions.py. Test schema only — never snapshot values.",
  "type": "object",
  "required": ["contributions"],
  "additionalProperties": false,
  "properties": {
    "contributions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["repo", "pr", "title", "url", "state", "date", "category"],
        "additionalProperties": false,
        "properties": {
          "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
          "pr": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "state": { "enum": ["merged", "open", "closed"] },
          "date": {
            "oneOf": [{ "type": "null" }, { "type": "string", "format": "date" }]
          },
          "category": {
            "enum": ["blockchain", "ai", "tooling", "projects", "portfolio", "academic"]
          },
          "ownership": {
            "enum": ["own", "external"]
          }
        }
      }
    }
  }
}
