{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/grants.json",
  "title": "Research grants and awards",
  "description": "Schema for _data/grants.yml — research funding rendered on /cv/ at the bottom of the page.",
  "type": "object",
  "required": ["grants"],
  "additionalProperties": false,
  "properties": {
    "grants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "funding_agency", "period", "status"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "grant_id": { "type": "string", "minLength": 1 },
          "funding_agency": { "type": "string", "minLength": 1 },
          "funding_agency_short": { "type": "string", "minLength": 1 },
          "funding_agency_url": { "type": "string", "format": "uri" },
          "region": { "type": "string", "minLength": 1 },
          "period": { "type": "string", "pattern": "^\\d{4}([\\u2013\\-]\\d{4})?$" },
          "role": { "type": "string", "minLength": 1 },
          "status": {
            "enum": ["active", "completed", "pending"]
          },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
