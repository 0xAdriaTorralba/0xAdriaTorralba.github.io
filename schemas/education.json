{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/education.json",
  "title": "Education entries",
  "description": "Schema for _data/education.yml — degrees rendered on /cv/ between the professional experience and certifications sections.",
  "type": "object",
  "required": ["education"],
  "additionalProperties": false,
  "properties": {
    "education": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["degree", "institution", "start_year", "location", "tags"],
        "additionalProperties": false,
        "properties": {
          "degree": { "type": "string", "minLength": 1 },
          "institution": { "type": "string", "minLength": 1 },
          "institution_url": { "type": "string", "format": "uri" },
          "logo": { "type": "string", "minLength": 1 },
          "start_year": { "type": "string", "pattern": "^\\d{4}$" },
          "end_year": {
            "oneOf": [{ "type": "null" }, { "type": "string", "pattern": "^\\d{4}$" }]
          },
          "location": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": ["cryptography", "blockchain", "data-science", "mathematics", "computer-science"]
            }
          }
        }
      }
    }
  }
}
