---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <style>
    /* Two-column about header: profile on the left, bio on the right. */
    .about-top {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.75rem;
      margin-bottom: 2.5rem;
    }
    @media (min-width: 768px) {
      .about-top {
        grid-template-columns: minmax(180px, 30%) 1fr;
        gap: 2.5rem;
        align-items: start;
      }
    }
    .about-top__profile {
      text-align: left;
    }
    .about-top__profile .more-info {
      margin-top: 1rem;
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .about-top__bio > p:first-child {
      margin-top: 0;
    }

    /* Uniform spacing for every section heading after the header. */
    .post article > h2 {
      margin-top: 2.25rem;
      margin-bottom: 0.5rem;
    }

    /* Clear visual break between the github heatmap and the contact icons. */
    .post .social {
      margin-top: 3rem;
      padding-top: 1.75rem;
      border-top: 1px solid var(--global-divider-color);
    }
  </style>

  <article>
    {% if page.profile %}
      <div class="about-top">
        <div class="about-top__profile" id="profile-container">
          {% if page.profile.image %}
            {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
            {% if page.profile.image_circular %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
            {% else %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
            {% endif %}
            {% capture sizes %}(min-width: 768px) 260px, 80vw{% endcapture %}
            {%
              include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
              cache_bust=true
            %}
          {% endif %}
          {% if page.profile.more_info %}
            <div class="more-info">{{ page.profile.more_info }}</div>
          {% endif %}
        </div>
        <div class="about-top__bio">{{ content }}</div>
      </div>
    {% else %}
      <div>{{ content }}</div>
    {% endif %}

    <!-- Recent security work -->
    {% if page.recent_security and page.recent_security.enabled %}
      <h2>
        <a href="{{ '/security/' | relative_url }}" style="color: inherit">recent security work</a>
      </h2>
      {% include recent_security.liquid limit=page.recent_security.limit %}
    {% endif %}

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">latest news</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- GitHub activity heatmap -->
    {% if page.github_activity and page.github_activity.enabled %}
      <h2>
        <a href="{{ '/github/' | relative_url }}" style="color: inherit">github</a>
      </h2>
      {% include github_heatmap.liquid %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% include social.liquid %}</div>

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>

<script src="{{ '/assets/js/profile-easter-egg.js' | relative_url | bust_file_cache }}" defer></script>
